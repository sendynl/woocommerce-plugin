# Copy to .env and uncomment what you need. Everything works without a .env file.

# Pin versions (default: latest for both)
# Pinning WP_VERSION skips the automatic core update on provisioning, so also
# pin WC_VERSION to a WooCommerce release compatible with that WordPress.
#WP_VERSION=6.7
#WC_VERSION=9.5.1

# Pin host ports (default: 0 = Docker assigns a free port; ./develop up prints the URL)
#WP_PORT=8080
#MYSQL_PORT=3308

# Locale for core + WooCommerce + Sendy language packs (default: nl_NL).
# Use en_US for automated sessions that assert on UI strings.
#WP_LOCALE=nl_NL

# WooCommerce High-Performance Order Storage (default: on; set off to test legacy order storage)
#WC_HPOS=on

# Tunnel mode needs no configuration: ./develop up --tunnel uses an account-less
# Cloudflare quick tunnel with a random *.trycloudflare.com URL per boot.
